AI_TIMEOUT_SECONDS=180
# Copy this file to .env and fill in values before running docker compose.

# Required for AI report generation
GROQ_API_KEY=your_groq_api_key_here
ENABLE_AI_REPORT_GENERATION=0

# Database (set these to your existing PostgreSQL server in pgAdmin)
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=compliance_db
DB_USER=postgres
DB_PASSWORD=nabilah

# Optional app secret
FLASK_SECRET_KEY=change-me

# Application timezone (used in Tarikh Jana / generated timestamps)
APP_TIMEZONE=Asia/Kuala_Lumpur

# Host port mapping for Docker (change if 5050 is unavailable)
APP_PORT=5050

# Session and cookie security
# Set to 1 in HTTPS production deployments.
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
SESSION_IDLE_TIMEOUT_MINUTES=120

# Keep disabled in production. Enable only for local demo fallback login.
ENABLE_DEMO_LOGIN_FALLBACK=0
